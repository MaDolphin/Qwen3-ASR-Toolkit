# =========================
# 基础路径
# =========================
PROJECT_DIR=/workspace/project/Qwen3-ASR-Toolkit

# =========================
# Conda 环境
# =========================
# 留空表示使用当前 shell 环境；设置为 qwen-asr 表示脚本自动 conda activate qwen-asr
CONDA_ENV=qwen-asr

# =========================
# GPU 选择
# =========================
# 默认 ASR 和 ForcedAligner 使用同一张卡。多卡机器上可改成 0、1、2 等。
QWEN3_CUDA_VISIBLE_DEVICES=0

# 可选分卡：留空则继承 QWEN3_CUDA_VISIBLE_DEVICES。
QWEN3_ASR_CUDA_VISIBLE_DEVICES=
QWEN3_ALIGNER_CUDA_VISIBLE_DEVICES=

# =========================
# 模型路径
# =========================
QWEN3_ASR_MODEL_PATH=/workspace/project/Qwen3-ASR-Toolkit/models/Qwen3-ASR-1.7B
QWEN3_ALIGNER_MODEL_PATH=/workspace/project/Qwen3-ASR-Toolkit/models/Qwen3-ForcedAligner-0.6B

# =========================
# ASR Native Server
# =========================
QWEN3_ASR_HOST=0.0.0.0
QWEN3_ASR_PORT=10012
QWEN3_ASR_GPU_MEMORY_UTILIZATION=0.30
QWEN3_ASR_KV_CACHE_MEMORY_BYTES=8G
QWEN3_ASR_CPU_OFFLOAD_GB=0
QWEN3_ASR_MAX_MODEL_LEN=65536
QWEN3_ASR_MAX_NEW_TOKENS=128
# ASR 模型推理固定为单 worker 串行执行；该参数保留为兼容项，建议保持 1。
QWEN3_ASR_MAX_CONCURRENT_JOBS=1
# 离线长音频分段提交线程数；实时延迟敏感时可降为 1。
QWEN3_ASR_OFFLINE_NUM_THREADS=2
QWEN3_ASR_VAD_TARGET_SEGMENT_S=45
QWEN3_ASR_VAD_MAX_SEGMENT_S=60
QWEN3_ASR_CHUNK_SIZE_SEC=1.0
QWEN3_ASR_UNFIXED_CHUNK_NUM=2
QWEN3_ASR_UNFIXED_TOKEN_NUM=5
QWEN3_ASR_AUDIO_QUEUE_SIZE=8
QWEN3_ASR_SEND_QUEUE_SIZE=32
QWEN3_ASR_DECODE_TIMEOUT_SEC=0
QWEN3_ASR_DTYPE=auto
QWEN3_ASR_ENFORCE_EAGER=0

# =========================
# ForcedAligner Server
# =========================
QWEN3_ALIGNER_HOST=0.0.0.0
QWEN3_ALIGNER_PORT=10013
QWEN3_ALIGNER_MODE=remote
QWEN3_ALIGNER_BASE_URL=http://127.0.0.1:10013
QWEN3_ALIGNER_API_KEY=EMPTY
QWEN3_ALIGNER_GPU_MEMORY_UTILIZATION=0.10
QWEN3_ALIGNER_KV_CACHE_MEMORY_BYTES=2G
QWEN3_ALIGNER_CPU_OFFLOAD_GB=0
QWEN3_ALIGNER_TIMEOUT_S=120
QWEN3_ALIGNER_TIMESTAMP_SEGMENT_TIME_MS=80

# =========================
# Gradio Client Server
# =========================
QWEN3_GRADIO_ENABLE=1
QWEN3_GRADIO_HOST=0.0.0.0
QWEN3_GRADIO_PORT=7860
QWEN3_GRADIO_SHARE=0
QWEN3_GRADIO_SERVER=http://127.0.0.1:10012

# =========================
# 离线加载
# =========================
HF_HUB_OFFLINE=1
TRANSFORMERS_OFFLINE=1

# =========================
# CLI 默认远程访问示例
# =========================
QWEN3_ASR_SERVER=http://127.0.0.1:10012
